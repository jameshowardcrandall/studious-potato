# Copy this file to `.env` and fill in values for your environment.
# Never commit a real .env — see .gitignore.

# Dataverse environment URL (trailing slash optional)
DATAVERSE_URL=https://orgxxxxxxxx.crm.dynamics.com/

# Azure AD tenant ID hosting the Dataverse environment
TENANT_ID=00000000-0000-0000-0000-000000000000

# MCP client ID for the agent that will call Dataverse MCP tools.
#   Claude Code:           0c412cc3-0dd6-449b-987f-05b053db9457
#   GitHub Copilot CLI:    aebc6443-996d-45c2-90f0-388ff96faa56
MCP_CLIENT_ID=0c412cc3-0dd6-449b-987f-05b053db9457

# Dataverse solution + publisher this project writes to
SOLUTION_NAME=ArmyGuardLandingPage
PUBLISHER_PREFIX=arng

# PAC CLI auth profile name (created via `pac auth create --name ...`)
PAC_AUTH_PROFILE=armyguard-dev

# Optional: service principal auth (for CI/CD). Leave blank for interactive auth.
# CLIENT_ID=
# CLIENT_SECRET=
